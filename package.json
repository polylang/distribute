{
	"name": "@wpsyntex/distribute",
	"version": "1.0.0",
	"description": "Build WordPress plugin distribution ZIPs from consumer project roots.",
	"type": "module",
	"bin": {
		"distribute": "./bin/distribute.js",
		"verify-dist": "./bin/verify-dist.js"
	},
	"exports": {
		".": "./src/index.js"
	},
	"files": [
		"bin",
		"src"
	],
	"scripts": {
		"test:unit": "NODE_OPTIONS=--experimental-vm-modules wp-scripts test-unit-js --config jest-unit.config.cjs",
		"test:coverage": "NODE_OPTIONS=--experimental-vm-modules wp-scripts test-unit-js --config jest-unit.config.cjs --coverage",
		"test:smoke": "node tests/smoke/verify-polylang-dist.js",
		"lint": "wp-scripts lint-js"
	},
	"keywords": [
		"polylang",
		"wordpress",
		"distribution",
		"zip"
	],
	"author": "WP Syntex",
	"license": "GPL-3.0-or-later",
	"repository": {
		"type": "git",
		"url": "https://github.com/polylang/distribute.git"
	},
	"bugs": {
		"url": "https://github.com/polylang/distribute/issues"
	},
	"engines": {
		"node": ">=18.12.0"
	},
	"dependencies": {
		"minimatch": "^10.2.2"
	},
	"publishConfig": {
		"access": "public"
	},
	"devDependencies": {
		"@jest/globals": "^30.2.0",
		"@wordpress/scripts": "^31.4.0"
	}
}
